<!DOCTYPE html>
<html>

<head>
  <style>
    body {
      font-family: Arial, sans-serif;
      background-color: #f4f4f4;
      padding: 20px;
    }

    .container {
      max-width: 600px;
      margin: 0 auto;
      background: white;
      padding: 30px;
      border-radius: 10px;
      border-left: 5px solid #25D366;
    }

    .tracking-box {
      background-color: #f0f0f0;
      padding: 20px;
      text-align: center;
      border-radius: 5px;
      margin: 20px 0;
    }

    .tracking-code {
      font-size: 24px;
      font-weight: bold;
      color: #333;
      letter-spacing: 2px;
    }
  </style>
</head>

<body>
  <div class="container">
    <div style="text-align: center; margin-bottom: 30px;">
      <img src="https://dnshop.com.ar/wp-content/uploads/2026/03/logodnstyle.png" alt="DN shop"
        style="height: 100px; width: auto; display: block; margin: 0 auto;">
    </div>
    <h2>Your order is on its way! </h2>
    <p>Hello {{name}},</p>
    <p>Great news! Your order <strong>#{{order_id}}</strong> has been dispatched and is on its way to your address.</p>

    {{#if tracking_number}}
    <div class="tracking-box">
      <p>Your tracking number:</p>
      <div class="tracking-code">{{tracking_number}}</div>
      {{#if tracking_url}}
      <br />
      <a href="{{tracking_url}}" style="color: #007cba; text-decoration: none;">Track shipment</a>
      {{/if}}
    </div>
    {{else}}
    <p>Your order will arrive soon.</p>
    {{/if}}

    <p>Thank you for choosing DN shop Store.</p>
  </div>
</body>

</html>